<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<title>Abbo's Colour Game 🎨</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@700;800;900&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Nunito',sans-serif;min-height:100vh;background:linear-gradient(160deg,#fff9e6 0%,#e8f7ff 100%);display:flex;align-items:center;justify-content:center;padding:16px;}
#wrap{width:100%;max-width:480px;text-align:center;}
#mascot{font-size:56px;display:inline-block;animation:bounce 2s infinite ease-in-out;user-select:none;}
@keyframes bounce{0%,100%{transform:translateY(0);}50%{transform:translateY(-10px);}}
#score-bar{display:flex;justify-content:center;gap:8px;margin:10px 0 14px;}
.star{font-size:28px;filter:grayscale(1);opacity:0.25;transition:all 0.3s;}
.star.lit{filter:none;opacity:1;transform:scale(1.2);}
#instruction{font-family:'Fredoka One',cursive;font-size:clamp(20px,5vw,28px);color:#222;margin:0 0 20px;min-height:50px;line-height:1.3;padding:0 8px;}
#instruction span{display:inline-block;padding:4px 16px;border-radius:100px;font-size:clamp(22px,5.5vw,30px);}
#choices{display:grid;grid-template-columns:1fr 1fr;gap:14px;max-width:440px;margin:0 auto;}
.choice-btn{background:white;border:3px solid #e0e0e0;border-radius:20px;padding:16px 10px;cursor:pointer;transition:transform 0.15s,border-color 0.15s;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;min-height:130px;outline:none;-webkit-tap-highlight-color:transparent;}
.choice-btn:active{transform:scale(0.93);}
.shape-label{font-family:'Fredoka One',cursive;font-size:14px;color:#999;}
.choice-btn.correct{border-color:#4cd964;background:#f0fff4;animation:popC 0.5s ease;}
.choice-btn.wrong{border-color:#ff3b30;background:#fff0ef;animation:shake 0.4s ease;}
@keyframes popC{0%{transform:scale(1);}40%{transform:scale(1.12);}70%{transform:scale(0.96);}100%{transform:scale(1);}}
@keyframes shake{0%,100%{transform:translateX(0);}20%{transform:translateX(-8px);}40%{transform:translateX(8px);}60%{transform:translateX(-6px);}80%{transform:translateX(6px);}}
#feedback{font-family:'Fredoka One',cursive;font-size:26px;min-height:40px;margin:14px 0 6px;}
#progress{font-size:12px;color:#bbb;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-top:4px;}
#celebration{display:none;position:fixed;inset:0;background:rgba(255,255,255,0.95);flex-direction:column;align-items:center;justify-content:center;z-index:99;gap:14px;}
#celebration.show{display:flex;}
.big-emoji{font-size:80px;animation:bounce 1s infinite;}
#celebration h2{font-family:'Fredoka One',cursive;font-size:38px;color:#ff9500;}
#celebration p{font-size:18px;color:#555;font-weight:700;}
#restart-btn{background:#5ac8fa;color:white;border:none;border-radius:100px;padding:16px 40px;font-family:'Fredoka One',cursive;font-size:24px;cursor:pointer;margin-top:6px;}
#restart-btn:active{transform:scale(0.95);}
#tap-start{display:flex;position:fixed;inset:0;background:linear-gradient(160deg,#fff9e6,#e8f7ff);flex-direction:column;align-items:center;justify-content:center;z-index:100;gap:16px;cursor:pointer;}
#tap-start h1{font-family:'Fredoka One',cursive;font-size:clamp(28px,7vw,42px);color:#ff9500;}
#tap-start p{font-size:18px;color:#888;font-weight:700;}
.tap-emoji{font-size:80px;animation:bounce 1.5s infinite;}
</style>
</head>
<body>
<div id="tap-start" onclick="initGame()">
  <div class="tap-emoji">🦁</div>
  <h1>Abbo's Colour Game!</h1>
  <p>Tap anywhere to start 🎉</p>
</div>
<div id="wrap">
  <div id="celebration">
    <div class="big-emoji">🎉</div>
    <h2>Amazing Abbo!</h2>
    <p id="final-msg"></p>
    <button id="restart-btn" onclick="startGame()">Play Again!</button>
  </div>
  <div id="mascot">🦁</div>
  <div id="score-bar">
    <span class="star" id="s1">⭐</span>
    <span class="star" id="s2">⭐</span>
    <span class="star" id="s3">⭐</span>
    <span class="star" id="s4">⭐</span>
    <span class="star" id="s5">⭐</span>
  </div>
  <div id="instruction">Loading...</div>
  <div id="choices"></div>
  <div id="feedback"></div>
  <div id="progress"></div>
</div>

<script>
const AUDIO_SRC = {
  "great_job": "data:audio/mp3;base64,",
  "hello_abbo": "data:audio/mp3;base64,",
  "hey": "data:audio/mp3;base64,",
  "hey_abbo": "data:audio/mp3;base64,",
  "lets_go_again": "data:audio/mp3;base64,",
  "oops": "data:audio/mp3;base64,",
  "ready_to_play": "data:audio/mp3;base64,",
  "show_blue_circle": "data:audio/mp3;base64,",
  "show_blue_star": "data:audio/mp3;base64,",
  "show_green_heart": "data:audio/mp3;base64,",
  "show_green_star": "data:audio/mp3;base64,",
  "show_red_heart": "data:audio/mp3;base64,",
  "that_is_great": "data:audio/mp3;base64,",
  "thats_great": "data:audio/mp3;base64,",
  "thats_great_abbo": "data:audio/mp3;base64,",
  "thats_nice": "data:audio/mp3;base64,",
  "try_again": "data:audio/mp3;base64,",
  "woo": "data:audio/mp3;base64,",
  "wow": "data:audio/mp3;base64,",
  "yes": "data:audio/mp3;base64,",
};


// ── AudioContext engine ──────────────────────────────────────────
let actx = null;
const decoded = {};   // key -> AudioBuffer

async function initAudio() {
  actx = new (window.AudioContext || window.webkitAudioContext)();
  // Decode all clips up front
  const keys = Object.keys(AUDIO_SRC);
  await Promise.all(keys.map(async key => {
    const b64 = AUDIO_SRC[key].split(',')[1];
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    decoded[key] = await actx.decodeAudioData(bytes.buffer);
  }));
  console.log('All audio decoded:', Object.keys(decoded).length, 'clips');
}

let currentSource = null;
function playClip(key, onDone) {
  if (!actx || !decoded[key]) {
    console.warn('Missing clip:', key);
    if (onDone) onDone();
    return;
  }
  if (currentSource) {
    currentSource.onended = null;
    try { currentSource.stop(); } catch(e){}
    currentSource = null;
  }
  if (actx.state === 'suspended') actx.resume();
  const src = actx.createBufferSource();
  src.buffer = decoded[key];
  src.connect(actx.destination);
  src.onended = () => { currentSource = null; if (onDone) onDone(); };
  src.start(0);
  currentSource = src;
  console.log('Playing:', key);
}

// Chain multiple clips one after another
function playChain(keys, onDone) {
  if (!keys.length) { if (onDone) onDone(); return; }
  const [first, ...rest] = keys;
  playClip(first, () => {
    if (rest.length) setTimeout(() => playChain(rest, onDone), 80);
    else if (onDone) onDone();
  });
}

// ── Game data ────────────────────────────────────────────────────
const ROUNDS = [
  { color:'red',   hex:'#FF3B30', label:'Red',   shape:'heart',  audioKey:'show_red_heart' },
  { color:'blue',  hex:'#007AFF', label:'Blue',  shape:'circle', audioKey:'show_blue_circle' },
  { color:'green', hex:'#34C759', label:'Green', shape:'star',   audioKey:'show_green_star' },
  { color:'blue',  hex:'#007AFF', label:'Blue',  shape:'star',   audioKey:'show_blue_star' },
  { color:'green', hex:'#34C759', label:'Green', shape:'heart',  audioKey:'show_green_heart' },
];
const ALL_COLORS = [
  {color:'red',    hex:'#FF3B30', label:'Red'},
  {color:'blue',   hex:'#007AFF', label:'Blue'},
  {color:'green',  hex:'#34C759', label:'Green'},
  {color:'yellow', hex:'#FFD60A', label:'Yellow'},
  {color:'orange', hex:'#FF9500', label:'Orange'},
  {color:'purple', hex:'#AF52DE', label:'Purple'},
  {color:'pink',   hex:'#FF2D95', label:'Pink'},
];
const ALL_SHAPES = ['circle','heart','star','square','triangle','diamond'];
const PRAISE = ['thats_great','thats_great_abbo','wow','yes','that_is_great','thats_nice','woo','great_job'];
const TRANSITIONS = ['hey_abbo','hey','lets_go_again'];
const MASCOTS = ['🦁','🐸','🐼','🦊','🐻','🐨','🦄','🐯'];

let round = 0, correct = 0, canClick = true, roundOrder = [];

function rand(arr){ return arr[Math.floor(Math.random()*arr.length)]; }
function shuffle(a){ const b=[...a]; for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];} return b; }

function drawShape(shape, color, size=72){
  const s=size;
  const svg=(body)=>`<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}" xmlns="http://www.w3.org/2000/svg">${body}</svg>`;
  if(shape==='circle')   return svg(`<circle cx="${s/2}" cy="${s/2}" r="${s/2-3}" fill="${color}" stroke="rgba(0,0,0,0.07)" stroke-width="2"/>`);
  if(shape==='square')   return svg(`<rect x="5" y="5" width="${s-10}" height="${s-10}" rx="10" fill="${color}" stroke="rgba(0,0,0,0.07)" stroke-width="2"/>`);
  if(shape==='triangle') return svg(`<polygon points="${s/2},5 ${s-5},${s-5} 5,${s-5}" fill="${color}" stroke="rgba(0,0,0,0.07)" stroke-width="2"/>`);
  if(shape==='diamond')  return svg(`<polygon points="${s/2},4 ${s-4},${s/2} ${s/2},${s-4} 4,${s/2}" fill="${color}" stroke="rgba(0,0,0,0.07)" stroke-width="2"/>`);
  if(shape==='heart')    return svg(`<path d="M${s/2} ${s*.82} C${s*.1} ${s*.5},${s*.1} ${s*.15},${s/2} ${s*.3} C${s*.9} ${s*.15},${s*.9} ${s*.5},${s/2} ${s*.82}Z" fill="${color}" stroke="rgba(0,0,0,0.07)" stroke-width="2"/>`);
  if(shape==='star'){
    function sp(cx,cy,R,r){let p='';for(let i=0;i<10;i++){const a=(Math.PI/5)*i-Math.PI/2,rd=i%2===0?R:r;p+=`${cx+rd*Math.cos(a)},${cy+rd*Math.sin(a)} `;}return p.trim();}
    return svg(`<polygon points="${sp(s/2,s/2,s/2-3,s/4)}" fill="${color}" stroke="rgba(0,0,0,0.07)" stroke-width="2"/>`);
  }
  return '';
}

let target = null;

function buildRound(){
  canClick = true;
  document.getElementById('feedback').textContent='';
  document.getElementById('mascot').textContent = rand(MASCOTS);
  target = roundOrder[round];

  const otherColors = shuffle(ALL_COLORS.filter(c=>c.color!==target.color));
  const otherShapes = shuffle(ALL_SHAPES.filter(s=>s!==target.shape));
  const distractors = [
    {...otherColors[0], shape:otherShapes[0]},
    {...otherColors[1], shape:otherShapes[1]},
    {...otherColors[2], shape:rand(ALL_SHAPES.filter(s=>s!==target.shape))},
  ];
  const choices = shuffle([target, ...distractors]);

  document.getElementById('instruction').innerHTML =
    `Show me the <span style="background:${target.hex}22;color:${target.hex};border:2px solid ${target.hex}55;">${target.label} ${target.shape}</span>`;
  document.getElementById('progress').textContent = `Round ${round+1} of ${roundOrder.length}`;

  const el = document.getElementById('choices');
  el.innerHTML='';
  choices.forEach(item=>{
    const btn=document.createElement('button');
    btn.className='choice-btn';
    btn.innerHTML=drawShape(item.shape,item.hex,72)+`<span class="shape-label">${item.label} ${item.shape}</span>`;
    btn.onclick=()=>handleChoice(btn,item);
    el.appendChild(btn);
  });

  setTimeout(()=>playClip(target.audioKey), 300);
}

function handleChoice(btn, item){
  if(!canClick) return;
  const ok = item.color===target.color && item.shape===target.shape;
  if(ok){
    canClick=false;
    btn.classList.add('correct');
    correct++;
    lightStar(correct);
    round++;
    if(round>=roundOrder.length){
      playClip(rand(PRAISE), ()=> setTimeout(showCelebration, 400));
    } else {
      const transition = rand(TRANSITIONS);
      playChain([rand(PRAISE), transition], buildRound);
    }
  } else {
    btn.classList.add('wrong');
    playChain(['oops','try_again'], ()=>{
      canClick=true;
      btn.classList.remove('wrong');
    });
  }
}

function lightStar(n){
  const s=document.getElementById('s'+n);
  if(s) s.classList.add('lit');
}

function showCelebration(){
  playClip('great_job');
  document.getElementById('final-msg').textContent=`You got ${correct} out of ${roundOrder.length} right! ⭐`;
  document.getElementById('celebration').classList.add('show');
}

function startGame(){
  round=0; correct=0;
  roundOrder = shuffle([...ROUNDS]);
  document.getElementById('celebration').classList.remove('show');
  document.getElementById('feedback').textContent='';
  for(let i=1;i<=5;i++){
    const s=document.getElementById('s'+i);
    if(s) s.classList.remove('lit');
  }
  playChain(['hello_abbo','ready_to_play'], buildRound);
}

async function initGame(){
  document.getElementById('tap-start').style.display='none';
  await initAudio();
  startGame();
}
</script>
</body>
</html>